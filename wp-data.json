  "textEls": [
    {
      "tag": "H1",
      "text": "What if it’s time we look down\nto move forward?",
      "font": "Cormorant Garamond",
      "size": "72px",
      "weight": "400",
      "color": "rgb(210, 206, 200)"
    },
    {
      "tag": "H1",
      "text": "Building food security starts with education",
      "font": "Cormorant Garamond",
      "size": "56px",
      "weight": "400",
      "color": "rgb(210, 206, 200)"
    },
    {
      "tag": "H1",
      "text": "Mycelium Resources and Content to Date",
      "font": "Cormorant Garamond",
      "size": "39px",
      "weight": "700",
      "color": "rgb(95, 161, 214)"
    },
    {
      "tag": "H1",
      "text": "240",
      "font": "Lora",
