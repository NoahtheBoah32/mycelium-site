---
const links = [
  { href: "#take-action", label: "Take Action" },
  { href: "/about", label: "About" },
  { href: "/", label: "Home" },
  { href: "/resources", label: "Resources" },
];
const currentPath = Astro.url.pathname;
---

<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <svg class="logo-icon" width="28" height="28" viewBox="0 0 28 28" fill="none">
        <circle cx="5" cy="5" r="3" fill="#6b7a2a"/>
        <circle cx="14" cy="5" r="3" fill="#8a9a3a"/>
        <circle cx="23" cy="5" r="3" fill="#6b7a2a"/>
        <circle cx="5" cy="14" r="3" fill="#8a9a3a"/>
        <circle cx="14" cy="14" r="3" fill="#D4A832"/>
        <circle cx="23" cy="14" r="3" fill="#8a9a3a"/>
        <circle cx="5" cy="23" r="3" fill="#6b7a2a"/>
        <circle cx="14" cy="23" r="3" fill="#8a9a3a"/>
        <circle cx="23" cy="23" r="3" fill="#6b7a2a"/>
      </svg>
      <span class="logo-text">MYCELIUM</span>
    </a>
    <div class="nav-center">
      {links.map(link => (
        <a
          href={link.href}
          class:list={["nav-link", { active: currentPath === link.href }]}
        >
          {link.label}
          <svg class="nav-chevron" width="10" height="6" viewBox="0 0 10 6" fill="none">
            <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </a>
      ))}
    </div>
    <a href="#join" class="nav-join">Join Us</a>
    <button class="nav-mobile-toggle" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<style>
  .nav {
    background: #1a1a14;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    position: sticky;
    top: 0;
    z-index: 1000;
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 32px;
    height: 56px;
  }
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }
  .logo-text {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.18em;
    color: #D2CEC8;
  }
  .nav-center {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .nav-link {
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 400;
    color: rgba(210,206,200,0.65);
    padding: 7px 14px;
    border-radius: 6px;
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  .nav-chevron {
    opacity: 0.3;
    transition: opacity 0.2s;
  }
  .nav-link:hover {
    color: #D2CEC8;
  }
  .nav-link:hover .nav-chevron { opacity: 0.6; }
  .nav-link.active {
    color: #D2CEC8;
    font-weight: 500;
  }
  .nav-join {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 500;
    color: #D2CEC8;
    border: 1px solid rgba(210,206,200,0.3);
    padding: 7px 20px;
    border-radius: 50px;
    transition: all 0.25s ease;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .nav-join:hover {
    border-color: rgba(210,206,200,0.6);
    background: rgba(210,206,200,0.08);
  }
  .nav-mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .nav-mobile-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: #D2CEC8;
    border-radius: 2px;
  }
  @media (max-width: 768px) {
    .nav-inner { padding: 0 20px; }
    .nav-center { display: none; }
    .nav-join { display: none; }
    .nav-mobile-toggle { display: flex; }
  }
</style>
