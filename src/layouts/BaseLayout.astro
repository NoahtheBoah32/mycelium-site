---
const {
  title = "Mycelium — Free Permaculture Education",
  stylesheets = [],
  inlineStyles = "",
  bodyClass = "",
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Mycelium is a free platform for permaculture education, documenting indigenous knowledge from the Philippines.">
  <meta name="theme-color" content="#4a4400">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  {stylesheets.map((href: string) => <link rel="stylesheet" href={href} />)}
  {inlineStyles && <style set:html={inlineStyles}></style>}
  <title>{title}</title>
</head>
<body class={bodyClass}>
  <slot />
  <style is:global>
    html { scroll-behavior: smooth; }
    body { -webkit-font-smoothing: antialiased; }
  </style>
</body>
</html>
