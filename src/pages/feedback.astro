<style>
  .wp-content { max-width: 100%; overflow-x: hidden; }
  .wp-content img { max-width: 100%; height: auto; }
  .wp-content .elementor-heading-title { margin: 0; }
  .wp-content .e-con-boxed .e-con-inner { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
  .wp-content .e-con { width: 100%; }
  .wp-content .e-flex { display: flex; }
  .wp-content .e-con-full { width: 100%; }
  .wp-content a { color: inherit; }
</style>
