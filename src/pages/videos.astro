---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Videos — Mycelium">
  <div class="page-wrap">
    <div class="page-section">
      <img src="/images/page-videos.png" alt="Mycelium Videos" class="page-img" loading="eager">
    </div>
  </div>
</BaseLayout>
<style>
  .page-wrap { background: #1e1e1e; }
  .page-section { position: relative; width: 100%; }
  .page-img { width: 100%; height: auto; display: block; }
</style>
