<style>
.vl-search-wrap *,
.vl-search-wrap *::before,
.vl-search-wrap *::after { box-sizing: border-box; }

.vl-search-wrap {
  --border: #E2DADA;
  --text:   #181516;
  --muted:  #7A6F6C;
  --bg:     #fff;
  --radius: 999px;
  --focus:  #3b82f6; /* blue */
  font-family: 'Geist', 'Inter', sans-serif;
  width: 100%;
  margin-bottom: 32px;
}

.vl-search-row {
  display: flex;
  align-items: center;
  gap: 12px;
  width: 100%;
}

.vl-input-wrap {
  position: relative !important;
  flex: 1;
  min-width: 0;
  display: block !important;
}

.vl-icon {
  position: absolute !important;
  left: 16px !important;
  top: 50% !important;
  transform: translateY(-50%) !important;
  width: 18px !important;
  height: 18px !important;
  color: var(--muted);
  pointer-events: none;
  z-index: 2;
  transition: color 0.2s;
}
.vl-input-wrap:focus-within .vl-icon { color: var(--focus); }

.vl-input {
  width: 100% !important;
  height: 50px !important;
  padding: 0 48px 0 48px !important;
  border: 1.5px solid var(--border) !important;
  border-radius: var(--radius) !important;
  background: var(--bg) !important;
  color: var(--text) !important;
  font-family: inherit !important;
  font-size: 15px !important;
  outline: none !important;
  box-shadow: none !important;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.vl-input::placeholder { color: var(--muted) !important; }
.vl-input:focus {
  border-color: var(--focus) !important;
  box-shadow: 0 0 0 3px rgba(59,130,246,0.15) !important;
}

.vl-clear-btn {
  position: absolute !important;
  right: 14px !important;
  top: 50% !important;
  transform: translateY(-50%) !important;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  border: none;
  background: #e5e7eb;
  color: #6b7280;
  cursor: pointer;
  align-items: center;
  justify-content: center;
  padding: 0;
  transition: background 0.2s, color 0.2s;
  z-index: 2;
}
.vl-clear-btn.visible { display: flex !important; }
.vl-clear-btn:hover { background: #d1d5db; color: #111; }
.vl-clear-btn svg { width: 13px; height: 13px; }

/* State */
.vl-state {
  padding: 20px 4px;
  color: var(--muted);
  font-size: 14px;
}
.vl-meta {
  font-size: 13px;
  color: var(--muted);
  margin: 20px 0 16px;
}

/* Cloned grid — mirrors the Loop Grid column layout */
.vl-cloned-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
@media (max-width: 1024px) { .vl-cloned-grid { grid-template-columns: repeat(2,1fr); } }
@media (max-width: 600px)  { .vl-cloned-grid { grid-template-columns: 1fr; } }

/* Each cloned card wrapper */
.vl-cloned-grid > div {
  width: 100% !important;
  max-width: 100% !important;
}
</style>

<script>
(function () {
  const DEBOUNCE = 280;

  const input       = document.getElementById('vlSearchInput');
  const clearBtn    = document.getElementById('vlSearchClear');
  const noResultsEl = document.getElementById('vlNoResults');
  const noResultsQ  = document.getElementById('vlNoResultsQuery');
  const resultsWrap = document.getElementById('vlResultsWrap');
  const clonedGrid  = document.getElementById('vlClonedGrid');
  const metaEl      = document.getElementById('vlResultsMeta');

  let tabsBlock     = null;
  let allCards      = [];   // { el, text } for every loop item across all tabs
  let debounceTimer = null;

  // ── Find the Elementor Tabs widget that follows this widget ─────
  function findTabsBlock() {
    const wrap = document.getElementById('vlSearchWrap');
    if (!wrap) return null;
    let node = wrap.closest('.elementor-widget') || wrap.parentElement;
    while (node) {
      let sib = node.nextElementSibling;
      while (sib) {
        if (
          sib.classList.contains('elementor-widget-n-tabs') ||
          sib.classList.contains('elementor-widget-tabs') ||
          sib.querySelector('.e-n-tabs, .elementor-tabs')
        ) return sib;
        sib = sib.nextElementSibling;
      }
      node = node.parentElement;
      if (!node || node === document.body) break;
    }
    return null;
  }

  // ── Collect every Loop Grid card across all tabs ────────────────
  function collectCards() {
    if (!tabsBlock) return;
    allCards = [];
    // Loop Grid items use .e-loop-item — covers Elementor 3.x
    const items = tabsBlock.querySelectorAll('.e-loop-item, .elementor-loop-item');
    items.forEach(item => {
      allCards.push({
        el:   item,
        // grab all visible text for matching
        text: (item.textContent || '').toLowerCase().trim(),
      });
    });
    console.log('[vl-search] Collected', allCards.length, 'cards');
  }

  // ── State helpers ───────────────────────────────────────────────
  function showTabs()  { if (tabsBlock) tabsBlock.style.display = ''; }
  function hideTabs()  { if (tabsBlock) tabsBlock.style.display = 'none'; }

  function clearResults() {
    noResultsEl.style.display = 'none';
    resultsWrap.style.display = 'none';
    clonedGrid.innerHTML = '';
    showTabs();
  }

  // ── Filter ──────────────────────────────────────────────────────
  function doFilter(query) {
    const q = query.trim().toLowerCase();

    if (!q) { clearResults(); return; }

    // Re-collect each time in case tabs lazy-loaded new content
    collectCards();

    const matched = allCards.filter(c => c.text.includes(q));

    hideTabs();
    noResultsEl.style.display = 'none';
    resultsWrap.style.display = 'none';
    clonedGrid.innerHTML = '';

    if (!matched.length) {
      noResultsQ.textContent = q;
      noResultsEl.style.display = 'block';
      return;
    }

    // Clone each matched card into the flat grid
    matched.forEach(c => {
      const clone = c.el.cloneNode(true);
      // Remove any inline width/max-width Elementor sets on the loop item
      clone.style.removeProperty('width');
      clone.style.removeProperty('max-width');
      clone.style.removeProperty('flex');
      clonedGrid.appendChild(clone);
    });

    metaEl.textContent = \`\${matched.length} result\${matched.length !== 1 ? 's' : ''} for "\${q}"\`;
    resultsWrap.style.display = 'block';
  }

  // ── Init (wait for Elementor to render the tabs/loop grid) ──────
  function init() {
    tabsBlock = findTabsBlock();
    if (!tabsBlock) {
      // Retry up to 3s for Elementor lazy render
      setTimeout(init, 300);
      return;
    }
    collectCards();
    console.log('[vl-search] Init complete. Tabs block found.');
  }

  document.addEventListener('DOMContentLoaded', () => setTimeout(init, 400));
  setTimeout(init, 800); // fallback

  // ── Events ──────────────────────────────────────────────────────
  input.addEventListener('input', () => {
    clearBtn.classList.toggle('visible', !!input.value);
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => doFilter(input.value), DEBOUNCE);
  });

  clearBtn.addEventListener('click', () => {
    input.value = '';
    clearBtn.classList.remove('visible');
    clearResults();
    input.focus();
  });

})();
</script>				</div>
