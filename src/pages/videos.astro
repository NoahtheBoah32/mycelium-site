---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
---

<BaseLayout title="Videos — Mycelium">
  <Nav />

  <section class="hero-videos">
    <div class="container">
      <h1>Videos</h1>
      <p class="subtitle">Indigenous knowledge documented on film. Watch, learn, share.</p>
    </div>
  </section>

  <section class="videos-content">
    <div class="container">
      <p class="coming-soon">Video library coming soon. We're documenting indigenous permaculture practices across the Philippines — from traditional composting to rice terrace water systems.</p>
      <div class="video-categories">
        <div class="category">
          <h3>Indigenous Practices</h3>
          <p>Traditional farming techniques passed down through generations of Filipino practitioners.</p>
        </div>
        <div class="category">
          <h3>Soil & Composting</h3>
          <p>Learn how to build living soil using methods that have worked for centuries.</p>
        </div>
        <div class="category">
          <h3>Food Forest Design</h3>
          <p>Multi-layered food production systems inspired by natural forest ecosystems.</p>
        </div>
        <div class="category">
          <h3>Water Management</h3>
          <p>From Ifugao rice terraces to modern rainwater harvesting — water wisdom from the Philippines.</p>
        </div>
      </div>
      <div class="cta-section">
        <p>Follow us on Instagram for the latest video content.</p>
        <a href="https://instagram.com/mycelium.learn" target="_blank" class="cta-button">@mycelium.learn</a>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <span class="logo-text">MYCELIUM</span>
        <p>Free permaculture education for the Philippines.</p>
      </div>
      <div class="footer-links">
        <a href="/about">About</a>
        <a href="/videos">Videos</a>
        <a href="/resources">Resources</a>
        <a href="/events">Events</a>
      </div>
      <div class="footer-social">
        <a href="https://instagram.com/mycelium.learn" target="_blank">Instagram</a>
      </div>
    </div>
  </footer>
</BaseLayout>

<style>
  .hero-videos { background: var(--olive); padding: 100px 0 60px; text-align: center; }
  .hero-videos h1 { font-family: var(--font-serif); font-size: 3rem; color: var(--cream); font-weight: 400; font-style: italic; }
  .subtitle { color: rgba(245,237,212,0.7); font-size: 1.1rem; margin-top: 16px; }
  .videos-content { background: var(--cream); padding: 80px 0; }
  .coming-soon { font-size: 1.1rem; color: #444; text-align: center; max-width: 600px; margin: 0 auto 48px; line-height: 1.7; }
  .video-categories { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; margin-bottom: 48px; }
  .category { padding: 28px; background: white; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
  .category h3 { font-family: var(--font-serif); font-size: 1.2rem; color: var(--olive); margin-bottom: 8px; }
  .category p { font-size: 0.9rem; color: #555; line-height: 1.6; }
  .cta-section { text-align: center; }
  .cta-section p { color: #666; margin-bottom: 16px; }
  .cta-button { display: inline-block; background: var(--olive); color: var(--cream); padding: 12px 28px; border-radius: 50px; font-weight: 600; font-size: 0.9rem; }
  .footer { background: var(--charcoal); padding: 60px 0; }
  .footer-inner { display: flex; justify-content: space-between; align-items: flex-start; gap: 40px; }
  .footer-brand .logo-text { font-weight: 700; letter-spacing: 0.12em; color: var(--white); font-size: 1rem; }
  .footer-brand p { color: rgba(255,255,255,0.5); font-size: 0.85rem; margin-top: 8px; }
  .footer-links, .footer-social { display: flex; gap: 24px; }
  .footer-links a, .footer-social a { color: rgba(255,255,255,0.6); font-size: 0.85rem; }
  .footer-links a:hover, .footer-social a:hover { color: var(--white); }
  @media (max-width: 768px) {
    .hero-videos h1 { font-size: 2.2rem; }
    .video-categories { grid-template-columns: 1fr; }
    .footer-inner { flex-direction: column; }
  }
</style>
