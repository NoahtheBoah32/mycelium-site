---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
---

<BaseLayout title="Events — Mycelium">
  <Nav />

  <section class="hero-events">
    <div class="container">
      <h1>Events</h1>
      <p class="subtitle">Workshops, seminars, and community gatherings. All free or community-funded.</p>
    </div>
  </section>

  <section class="events-content">
    <div class="container">
      <div class="events-list">
        <div class="event-card">
          <div class="event-date">
            <span class="date-month">APR</span>
            <span class="date-day">13</span>
          </div>
          <div class="event-info">
            <h3>How to Start an Intentional Community</h3>
            <p class="event-meta">Sunday, April 13 | 1:00 - 3:00 PM | Zoom</p>
            <p class="event-speaker">Speaker: Penny Reyes</p>
            <p class="event-desc">Learn the foundations of building intentional communities rooted in permaculture principles and shared values.</p>
            <span class="event-tag free">Free</span>
          </div>
        </div>

        <div class="event-card">
          <div class="event-date">
            <span class="date-month">APR</span>
            <span class="date-day">20</span>
          </div>
          <div class="event-info">
            <h3>Seed Saving Workshop</h3>
            <p class="event-meta">Sunday, April 20 | 10:00 AM - 12:00 PM | Online</p>
            <p class="event-speaker">Speaker: Engr. Abi Jastio</p>
            <p class="event-desc">Practical seed saving techniques for Philippine crops — preserving biodiversity one garden at a time.</p>
            <span class="event-tag free">Free</span>
          </div>
        </div>
      </div>

      <div class="past-events">
        <h2>Past Events</h2>
        <div class="past-event">
          <span class="past-date">Mar 29, 2026</span>
          <span class="past-title">Perma-Kapihan sa Eco-house — PPA Hereford St., Marikina</span>
        </div>
      </div>

      <div class="cta-section">
        <p>Want to host an event with Mycelium? Reach out to us.</p>
        <a href="https://instagram.com/mycelium.learn" target="_blank" class="cta-button">Contact Us</a>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <span class="logo-text">MYCELIUM</span>
        <p>Free permaculture education for the Philippines.</p>
      </div>
      <div class="footer-links">
        <a href="/about">About</a>
        <a href="/videos">Videos</a>
        <a href="/resources">Resources</a>
        <a href="/events">Events</a>
      </div>
      <div class="footer-social">
        <a href="https://instagram.com/mycelium.learn" target="_blank">Instagram</a>
      </div>
    </div>
  </footer>
</BaseLayout>

<style>
  .hero-events { background: var(--olive); padding: 100px 0 60px; text-align: center; }
  .hero-events h1 { font-family: var(--font-serif); font-size: 3rem; color: var(--cream); font-weight: 400; font-style: italic; }
  .subtitle { color: rgba(245,237,212,0.7); font-size: 1.1rem; margin-top: 16px; }
  .events-content { background: var(--cream); padding: 80px 0; }
  .events-list { display: flex; flex-direction: column; gap: 24px; margin-bottom: 60px; }
  .event-card { display: flex; gap: 24px; padding: 28px; background: white; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
  .event-date { display: flex; flex-direction: column; align-items: center; justify-content: center; min-width: 70px; padding: 12px; background: var(--olive); border-radius: 10px; }
  .date-month { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; color: var(--gold); text-transform: uppercase; }
  .date-day { font-size: 1.8rem; font-weight: 700; color: var(--cream); }
  .event-info h3 { font-family: var(--font-serif); font-size: 1.2rem; color: var(--text-dark); margin-bottom: 6px; }
  .event-meta { font-size: 0.85rem; color: var(--olive); font-weight: 500; margin-bottom: 4px; }
  .event-speaker { font-size: 0.85rem; color: #888; margin-bottom: 8px; }
  .event-desc { font-size: 0.9rem; color: #555; line-height: 1.6; margin-bottom: 12px; }
  .event-tag { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; padding: 4px 12px; border-radius: 20px; text-transform: uppercase; }
  .event-tag.free { background: rgba(74,68,0,0.1); color: var(--olive); }
  .past-events { margin-bottom: 48px; }
  .past-events h2 { font-family: var(--font-serif); font-size: 1.5rem; color: var(--text-dark); margin-bottom: 16px; }
  .past-event { display: flex; gap: 16px; padding: 12px 0; border-bottom: 1px solid rgba(0,0,0,0.08); }
  .past-date { font-size: 0.85rem; color: #888; min-width: 100px; }
  .past-title { font-size: 0.9rem; color: #444; }
  .cta-section { text-align: center; }
  .cta-section p { color: #666; margin-bottom: 16px; }
  .cta-button { display: inline-block; background: var(--olive); color: var(--cream); padding: 14px 36px; border-radius: 50px; font-weight: 600; font-size: 0.95rem; }
  .footer { background: var(--charcoal); padding: 60px 0; }
  .footer-inner { display: flex; justify-content: space-between; align-items: flex-start; gap: 40px; }
  .footer-brand .logo-text { font-weight: 700; letter-spacing: 0.12em; color: var(--white); font-size: 1rem; }
  .footer-brand p { color: rgba(255,255,255,0.5); font-size: 0.85rem; margin-top: 8px; }
  .footer-links, .footer-social { display: flex; gap: 24px; }
  .footer-links a, .footer-social a { color: rgba(255,255,255,0.6); font-size: 0.85rem; }
  .footer-links a:hover, .footer-social a:hover { color: var(--white); }
  @media (max-width: 768px) {
    .hero-events h1 { font-size: 2.2rem; }
    .event-card { flex-direction: column; }
    .footer-inner { flex-direction: column; }
  }
</style>
