---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
---

<BaseLayout title="Resources — Mycelium">
  <Nav />

  <section class="hero-resources">
    <div class="container">
      <h1>Resources</h1>
      <p class="subtitle">240+ curated permaculture resources. Free, verified, and accessible.</p>
    </div>
  </section>

  <section class="resources-content">
    <div class="container">
      <div class="resource-categories">
        <div class="resource-card">
          <span class="resource-count">50+</span>
          <h3>Indigenous Knowledge</h3>
          <p>Traditional practices documented from Filipino elders and indigenous communities.</p>
        </div>
        <div class="resource-card">
          <span class="resource-count">40+</span>
          <h3>Soil & Composting</h3>
          <p>Building living soil — from rice husk ash composting to vermicomposting guides.</p>
        </div>
        <div class="resource-card">
          <span class="resource-count">35+</span>
          <h3>Food Forest Design</h3>
          <p>Multi-layered food production systems for tropical climates.</p>
        </div>
        <div class="resource-card">
          <span class="resource-count">30+</span>
          <h3>Water Management</h3>
          <p>Rainwater harvesting, swales, and traditional Filipino water systems.</p>
        </div>
        <div class="resource-card">
          <span class="resource-count">45+</span>
          <h3>Plant Profiles</h3>
          <p>Philippine-specific plant guides for permaculture gardens and food forests.</p>
        </div>
        <div class="resource-card">
          <span class="resource-count">40+</span>
          <h3>Community Stories</h3>
          <p>How communities across the Philippines are building food security through permaculture.</p>
        </div>
      </div>
      <div class="cta-section">
        <p>All resources are free. No account needed. No paywalls.</p>
        <a href="https://mycelium-learn.com" target="_blank" class="cta-button">Browse Full Library</a>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <span class="logo-text">MYCELIUM</span>
        <p>Free permaculture education for the Philippines.</p>
      </div>
      <div class="footer-links">
        <a href="/about">About</a>
        <a href="/videos">Videos</a>
        <a href="/resources">Resources</a>
        <a href="/events">Events</a>
      </div>
      <div class="footer-social">
        <a href="https://instagram.com/mycelium.learn" target="_blank">Instagram</a>
      </div>
    </div>
  </footer>
</BaseLayout>

<style>
  .hero-resources { background: var(--olive); padding: 100px 0 60px; text-align: center; }
  .hero-resources h1 { font-family: var(--font-serif); font-size: 3rem; color: var(--cream); font-weight: 400; font-style: italic; }
  .subtitle { color: rgba(245,237,212,0.7); font-size: 1.1rem; margin-top: 16px; }
  .resources-content { background: var(--cream); padding: 80px 0; }
  .resource-categories { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-bottom: 48px; }
  .resource-card { padding: 32px; background: white; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); text-align: center; }
  .resource-count { font-family: var(--font-sans); font-size: 2rem; font-weight: 700; color: var(--olive); display: block; margin-bottom: 8px; }
  .resource-card h3 { font-family: var(--font-serif); font-size: 1.15rem; color: var(--text-dark); margin-bottom: 8px; }
  .resource-card p { font-size: 0.85rem; color: #666; line-height: 1.6; }
  .cta-section { text-align: center; }
  .cta-section p { color: #666; margin-bottom: 16px; }
  .cta-button { display: inline-block; background: var(--olive); color: var(--cream); padding: 14px 36px; border-radius: 50px; font-weight: 600; font-size: 0.95rem; }
  .footer { background: var(--charcoal); padding: 60px 0; }
  .footer-inner { display: flex; justify-content: space-between; align-items: flex-start; gap: 40px; }
  .footer-brand .logo-text { font-weight: 700; letter-spacing: 0.12em; color: var(--white); font-size: 1rem; }
  .footer-brand p { color: rgba(255,255,255,0.5); font-size: 0.85rem; margin-top: 8px; }
  .footer-links, .footer-social { display: flex; gap: 24px; }
  .footer-links a, .footer-social a { color: rgba(255,255,255,0.6); font-size: 0.85rem; }
  .footer-links a:hover, .footer-social a:hover { color: var(--white); }
  @media (max-width: 768px) {
    .hero-resources h1 { font-size: 2.2rem; }
    .resource-categories { grid-template-columns: 1fr; }
    .footer-inner { flex-direction: column; }
  }
</style>
