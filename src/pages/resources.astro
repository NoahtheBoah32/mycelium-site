/*# sourceURL=global-styles-inline-css */


a.card {
  text-decoration: none !important;
  color: inherit !important;
}

/*HOVER*/
/* Course Card Hover Effect */
.card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.card:hover {
    transform: scale(1.05);
    z-index: 10;
    position: relative;
}

/* Optional: Smooth transition for images inside */
.card img {
    transition: transform 0.3s ease;
}

.card:hover img {
    transform: scale(1.02);
}
	
	/*Header*/
	.card-header h4 {
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
	}




#ast-scroll-top {
    background-color: var(--e-global-color-c25bee6);
	border-radius: 50px;
}


/* More specific selectors */
body .card {
  position: relative;
  transition: transform 0.3s ease, z-index 0.3s ease;
}

body .card:hover {
  transform: scale(1.05) !important;
  z-index: 10 !important;
}

body .card .card-buttons {
  opacity: 0 !important;
  visibility: hidden !important;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}

body .card:hover .card-buttons {
  opacity: 1 !important;
  visibility: visible !important;
}

/* Mobile: Always show buttons */
@media (max-width: 768px) {
  body .card .card-buttons {
    opacity: 1 !important;
    visibility: visible !important;
    display: flex !important;
    flex-direction: row !important;
    gap: 10px !important;
    flex-wrap: nowrap !important;
  }
  
  /* Target the buttons directly - this is the key part */
  body .card .card-buttons a,
  body .card .card-buttons button {
    flex: 1 !important;
    justify-content: center;
    display: inline-flex !important;
    margin: 0 !important;
  }
  
  /* Optional: Disable scale on mobile */
  body .card:hover {
    transform: none !important;
  }
}


.text-description {
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}


