---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
---
<BaseLayout title="Resources — Mycelium">
  <SiteNav />
  <div class="page-wrap">
    <div class="page-section">
      <img src="/images/page-resources.png" alt="Mycelium Resources" class="page-img" loading="eager">
    </div>
  </div>
</BaseLayout>
<style>
  .page-wrap { background: #1e1e1e; }
  .page-section { position: relative; width: 100%; }
  .page-img { width: 100%; height: auto; display: block; }
</style>
