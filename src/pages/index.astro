---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
---

<BaseLayout title="Mycelium — Free Permaculture Education">
  <Nav />

  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="hero-inner">
      <h1 class="hero-h1">
        What if it's time we look down<br>to move forward?
      </h1>
      <a href="/resources" class="hero-btn">Start Your Journey</a>
    </div>
  </section>

  <!-- ═══ PHOTO STRIP ═══ -->
  <section class="photo-strip">
    <div class="strip-grid">
      <div class="strip-img"><img src="/images/hero-left.png" alt="Permaculture garden" loading="lazy"></div>
      <div class="strip-img"><img src="/images/hero-middle.png" alt="Mycelium close-up" loading="lazy"></div>
      <div class="strip-img"><img src="/images/hero-right.png" alt="Composting" loading="lazy"></div>
    </div>
  </section>

  <!-- ═══ MISSION ═══ -->
  <section class="mission">
    <div class="container">
      <h2 class="mission-h2">Building food security starts with education</h2>
      <p class="mission-body">
        Our goals start with confronting the fear of finding clear and uncomplicated permaculture
        education. The chaos of scattered resources, conflicting advice, and no clear starting point often
        turn eager learners away. Mycelium exists to bridge this gap — think the mycelial system which
        connects a mountain underground, the platform links scattered knowledge together to lower the
        barrier of learning. Mycelium strengthens permaculture education at its root, encouraging
        outward action to support that never-ending goal of achieving food sovereignty.
      </p>
    </div>
  </section>

  <!-- ═══ STATS ═══ -->
  <section class="stats">
    <div class="container">
      <p class="stats-label">Mycelium Resources and Content to Date</p>
      <div class="stats-row">
        <div class="stat-item">
          <span class="stat-num">240</span>
          <span class="stat-desc">RESOURCES CURATED</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-num">600+</span>
          <span class="stat-desc">HOURS OF ORGANIZED CONTENT</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-num">1</span>
          <span class="stat-desc">COMMUNITY IN ACTIVE IMPLEMENTATION</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FOUNDER ═══ -->
  <section class="founder">
    <div class="container founder-grid">
      <div class="founder-left">
        <div class="founder-photo-wrap">
          <img src="/images/founder-photo.png" alt="Tax Riego and the team" loading="lazy">
          <div class="founder-arrow">
            <img src="/images/arrow.png" alt="" class="arrow-img">
            <span class="founder-tag">That's me!</span>
          </div>
        </div>
      </div>
      <div class="founder-right">
        <h2 class="founder-h2">Why did I build Mycelium at 16?</h2>
        <p>I built Mycelium at 16 because I wanted uncomplicated permaculture guidance. I got exhausted finding conflicting advice and resources that didn't apply to me. So I spent the next year building a platform I couldn't find. With the guidance I got from the Philippine Permaculture Association and hours of curating content, Mycelium is now what I wish existed when I was searching alone at 2 am with too many tabs to count.</p>
        <a href="/about" class="gold-cta">READ MY FULL JOURNEY</a>
      </div>
    </div>
  </section>

  <!-- ═══ HOW WE OPERATE ═══ -->
  <section class="operate">
    <div class="container">
      <h2 class="section-heading">How We Operate</h2>
      <div class="operate-grid">
        <div class="op-card">
          <div class="op-icon">
            <img src="/images/zero-gatekeeping.png" alt="Zero Gatekeeping" width="120">
          </div>
          <h3>Zero Gatekeeping</h3>
          <p>100% Free, forever. No paywalls, no ads interrupting your learning. We believe that permaculture knowledge should be accessible to everyone, regardless of income or location.</p>
          <a href="/about" class="gold-cta small">OUR MISSION</a>
        </div>
        <div class="op-card">
          <div class="op-icon">
            <img src="/images/we-verify.png" alt="We verify every resource" width="120">
          </div>
          <h3>We verify every resource</h3>
          <p>We personally review every video, course, and article before adding it to Mycelium. Each resource is checked thoroughly, prioritizing beginner-friendliness.</p>
          <a href="/about" class="gold-cta small">OUR CRITERIA</a>
        </div>
        <div class="op-card">
          <div class="op-icon">
            <img src="/images/expert-partners.png" alt="We work with expert partners" width="120">
          </div>
          <h3>We work with expert partners</h3>
          <p>Our resources are credible and field-tested — built in partnership with the Baganihan Collective and shaped by contributions from the Philippine Permaculture Association (PPA).</p>
          <a href="/about#partners" class="gold-cta small">LEARN MORE</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CURATED VIDEOS ═══ -->
  <section class="videos-section">
    <div class="container">
      <h2 class="section-heading dark">Curated Permaculture Videos</h2>
      <p class="section-sub">Visual learning paths from beginner introductions to advanced techniques</p>
      <div class="video-grid">
        <a href="/videos" class="video-card">
          <div class="video-thumb">
            <img src="https://mycelium-learn.com/wp-content/uploads/2024/11/pexels-photo-2132250.jpeg" alt="Water Management" loading="lazy">
            <div class="play-btn"><svg width="20" height="20" viewBox="0 0 20 20" fill="#fff"><path d="M6 4l12 6-12 6z"/></svg></div>
            <span class="vid-duration">9 min</span>
          </div>
          <h3>Water Management Basics</h3>
          <p>Understanding water flow and simple catchment systems</p>
        </a>
        <a href="/videos" class="video-card">
          <div class="video-thumb">
            <img src="https://mycelium-learn.com/wp-content/uploads/2024/11/pexels-photo-8092437.jpeg" alt="Garden Bed" loading="lazy">
            <div class="play-btn"><svg width="20" height="20" viewBox="0 0 20 20" fill="#fff"><path d="M6 4l12 6-12 6z"/></svg></div>
            <span class="vid-duration">12 min</span>
          </div>
          <h3>Starting Your First Garden Bed</h3>
          <p>Practical steps to create your first no-dig garden bed</p>
        </a>
        <a href="/videos" class="video-card">
          <div class="video-thumb">
            <img src="https://mycelium-learn.com/wp-content/uploads/2024/11/pexels-photo-4505166.jpeg" alt="Water Management" loading="lazy">
            <div class="play-btn"><svg width="20" height="20" viewBox="0 0 20 20" fill="#fff"><path d="M6 4l12 6-12 6z"/></svg></div>
            <span class="vid-duration">9 min</span>
          </div>
          <h3>Water Management Basics</h3>
          <p>Understanding water flow and simple catchment systems</p>
        </a>
      </div>
      <div class="section-cta-wrap">
        <a href="/videos" class="outline-btn">View All Videos</a>
      </div>
    </div>
  </section>

  <!-- ═══ BLOG RESOURCES ═══ -->
  <section class="resources-section">
    <div class="container">
      <h2 class="section-heading">Organized Blog Resources</h2>
      <p class="section-sub light">Quality permaculture content organized by topic</p>
      <div class="resource-grid">
        <a href="/resources" class="resource-card">
          <div class="resource-img"><img src="https://mycelium-learn.com/wp-content/uploads/2024/11/pexels-photo-2132250.jpeg" alt="Resource" loading="lazy"></div>
          <div class="resource-info">
            <span class="resource-cat">GETTING STARTED</span>
            <h3>Starting Your First Garden Bed</h3>
            <p>A comprehensive guide to designing and building your first raised garden bed</p>
          </div>
        </a>
        <a href="/resources" class="resource-card">
          <div class="resource-img"><img src="https://mycelium-learn.com/wp-content/uploads/2024/11/pexels-photo-8092437.jpeg" alt="Resource" loading="lazy"></div>
          <div class="resource-info">
            <span class="resource-cat">GETTING STARTED</span>
            <h3>Starting Your First Garden Bed</h3>
            <p>A comprehensive guide to designing and building your first raised garden bed</p>
          </div>
        </a>
        <a href="/resources" class="resource-card">
          <div class="resource-img"><img src="https://mycelium-learn.com/wp-content/uploads/2024/11/pexels-photo-4505166.jpeg" alt="Resource" loading="lazy"></div>
          <div class="resource-info">
            <span class="resource-cat">GETTING STARTED</span>
            <h3>Starting Your First Garden Bed</h3>
            <p>A comprehensive guide to designing and building your first raised garden bed</p>
          </div>
        </a>
        <a href="/resources" class="resource-card">
          <div class="resource-img"><img src="https://mycelium-learn.com/wp-content/uploads/2024/11/pexels-photo-2132250.jpeg" alt="Resource" loading="lazy"></div>
          <div class="resource-info">
            <span class="resource-cat">GETTING STARTED</span>
            <h3>Starting Your First Garden Bed</h3>
            <p>A comprehensive guide to designing and building your first raised garden bed</p>
          </div>
        </a>
      </div>
      <div class="section-cta-wrap">
        <a href="/resources" class="outline-btn light">View All Resources</a>
      </div>
    </div>
  </section>

  <!-- ═══ COURSES ═══ -->
  <section class="courses-section">
    <div class="container">
      <h2 class="section-heading dark">Learning Pathways &amp; Courses</h2>
      <p class="section-sub">From free introductions to full PDC certifications</p>
      <div class="course-grid">
        <a href="/courses" class="course-card">
          <div class="course-img"><img src="https://mycelium-learn.com/wp-content/uploads/2024/11/pexels-photo-2132250.jpeg" alt="Course" loading="lazy"></div>
          <div class="course-info">
            <div class="course-meta"><span class="course-lessons">8 Lessons</span><span class="course-price">$ FREE</span></div>
            <h3>Grow Permaculture</h3>
            <p>Grow Permaculture offers a no-nonsense Permaculture Design Course (PDC) with practical worksheets and real knowledge.</p>
          </div>
        </a>
        <a href="/courses" class="course-card">
          <div class="course-img"><img src="https://mycelium-learn.com/wp-content/uploads/2024/11/pexels-photo-8092437.jpeg" alt="Course" loading="lazy"></div>
          <div class="course-info">
            <div class="course-meta"><span class="course-lessons">12 Lessons</span><span class="course-price">$ FREE</span></div>
            <h3>Oregon State University</h3>
            <p>Oregon State University's free Permaculture Design Course, 16 hours of professional education.</p>
          </div>
        </a>
        <a href="/courses" class="course-card">
          <div class="course-img"><img src="https://mycelium-learn.com/wp-content/uploads/2024/11/pexels-photo-4505166.jpeg" alt="Course" loading="lazy"></div>
          <div class="course-info">
            <div class="course-meta"><span class="course-lessons">10 Lessons</span><span class="course-price">$ FREE</span></div>
            <h3>ACE Permaculture</h3>
            <p>ACE Gardener's Australia offers a Permaculture Design Course.</p>
          </div>
        </a>
        <a href="/courses" class="course-card">
          <div class="course-img"><img src="https://mycelium-learn.com/wp-content/uploads/2024/11/pexels-photo-2132250.jpeg" alt="Course" loading="lazy"></div>
          <div class="course-info">
            <div class="course-meta"><span class="course-lessons">6 Lessons</span><span class="course-price">$ FREE</span></div>
            <h3>Permaculture Online</h3>
            <p>Permaculture Course Online founded by Morag Gamble, offers a Permaculture Design Course.</p>
          </div>
        </a>
      </div>
      <div class="section-cta-wrap">
        <a href="/courses" class="outline-btn">View All Courses</a>
      </div>
    </div>
  </section>

  <!-- ═══ FOOTER ═══ -->
  <footer class="site-footer">
    <div class="container footer-grid">
      <div class="footer-brand">
        <div class="footer-logo">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <circle cx="5" cy="5" r="3" fill="#6b7a2a"/><circle cx="14" cy="5" r="3" fill="#8a9a3a"/><circle cx="23" cy="5" r="3" fill="#6b7a2a"/>
            <circle cx="5" cy="14" r="3" fill="#8a9a3a"/><circle cx="14" cy="14" r="3" fill="#D4A832"/><circle cx="23" cy="14" r="3" fill="#8a9a3a"/>
            <circle cx="5" cy="23" r="3" fill="#6b7a2a"/><circle cx="14" cy="23" r="3" fill="#8a9a3a"/><circle cx="23" cy="23" r="3" fill="#6b7a2a"/>
          </svg>
          <span>MYCELIUM</span>
        </div>
        <p class="footer-tagline">Connecting scattered permaculture knowledge into clear learning pathways. Free, verified, and built for beginners ready to grow.</p>
      </div>
      <div class="footer-col">
        <h4>Learn</h4>
        <a href="/videos">Videos</a>
        <a href="/courses">Courses</a>
        <a href="/resources">Resources</a>
        <a href="/events">Events</a>
      </div>
      <div class="footer-col">
        <h4>Mycelium</h4>
        <a href="/about">About</a>
        <a href="/feedback">Feedback</a>
        <a href="/resources">Newsletter</a>
      </div>
      <div class="footer-col">
        <h4>Get In Touch</h4>
        <a href="mailto:myceliumlearning@gmail.com">Email:<br>myceliumlearning@gmail.com</a>
      </div>
    </div>
    <div class="container footer-bottom">
      <p>&copy; 2026 All Rights Reserved.</p>
      <p>Built with 🌱 for the permaculture community.</p>
    </div>
  </footer>
</BaseLayout>

<style>
  /* ═══ HERO ═══ */
  .hero {
    background: #43330B;
    padding: 80px 24px 48px;
    text-align: center;
  }
  .hero-inner {
    max-width: 800px;
    margin: 0 auto;
  }
  .hero-h1 {
    font-family: 'Lora', serif;
    font-size: clamp(2.2rem, 5.5vw, 3.8rem);
    font-weight: 400;
    font-style: normal;
    color: #D2CEC8;
    line-height: 0.68;
    letter-spacing: -0.01em;
    margin-bottom: 40px;
  }
  .hero-btn {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: clamp(0.85rem, 1.5vw, 1.1rem);
    font-weight: 500;
    color: #D2CEC8;
    background: #5A3A1C;
    border: none;
    padding: 12px 32px;
    border-radius: 68px;
    transition: all 0.3s ease;
    line-height: 1.36;
  }
  .hero-btn:hover {
    background: #6d4a28;
  }

  /* ═══ PHOTO STRIP ═══ */
  .photo-strip {
    background: #43330B;
    padding: 0 24px 64px;
  }
  .strip-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    max-width: 1000px;
    margin: 0 auto;
  }
  .strip-img {
    border-radius: 15px;
    overflow: hidden;
  }
  .strip-img img {
    width: 100%;
    aspect-ratio: 544.79 / 543.47;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .strip-img:hover img { transform: scale(1.04); }

  /* ═══ MISSION ═══ */
  .mission {
    background: #43330B;
    padding: 48px 0 72px;
    text-align: center;
  }
  .mission-h2 {
    font-family: 'Lora', serif;
    font-size: clamp(1.8rem, 4.5vw, 3.2rem);
    font-weight: 400;
    color: #D2CEC8;
    line-height: 0.68;
    letter-spacing: -0.01em;
    margin-bottom: 28px;
  }
  .mission-body {
    font-family: 'Lora', serif;
    font-size: clamp(0.85rem, 1.3vw, 1.05rem);
    line-height: 2.3;
    letter-spacing: -0.01em;
    color: #D2CEC8;
    max-width: 700px;
    margin: 0 auto;
  }

  /* ═══ STATS ═══ */
  .stats {
    background: #2B2F31;
    padding: 56px 0;
  }
  .stats-label {
    text-align: center;
    font-family: 'Lora', serif;
    font-size: 1rem;
    color: #5FA1D6;
    margin-bottom: 36px;
    font-style: italic;
  }
  .stats-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 48px;
  }
  .stat-item { text-align: center; }
  .stat-num {
    display: block;
    font-family: 'Lora', serif;
    font-size: clamp(2.8rem, 5.5vw, 4.2rem);
    font-weight: 400;
    color: #FAF7F0;
    line-height: 0.57;
    letter-spacing: -0.02em;
  }
  .stat-desc {
    display: block;
    font-family: 'Lora', serif;
    font-size: clamp(0.7rem, 1.1vw, 0.88rem);
    font-weight: 400;
    letter-spacing: -0.01em;
    color: #D2CEC8;
    margin-top: 14px;
    line-height: 2.7;
  }
  .stat-divider {
    width: 1px;
    height: 48px;
    background: rgba(255,255,255,0.12);
  }

  /* ═══ FOUNDER ═══ */
  .founder {
    background: #2F2A10;
    padding: 80px 0;
  }
  .founder-grid {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 48px;
    align-items: center;
  }
  .founder-photo-wrap {
    position: relative;
    width: fit-content;
    margin: 0 auto;
  }
  .founder-photo-wrap img:first-child {
    width: min(100%, 420px);
    object-fit: contain;
  }
  .founder-arrow {
    position: absolute;
    top: -10px;
    right: -60px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .arrow-img {
    width: 40px;
    height: auto;
  }
  .founder-tag {
    font-family: 'Lora', serif;
    font-weight: 400;
    font-size: 0.85rem;
    color: #FFFFFF;
    white-space: nowrap;
  }
  .founder-h2 {
    font-family: 'Lora', serif;
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 400;
    color: #FAF7F0;
    line-height: 1.03;
    letter-spacing: -0.01em;
    margin-bottom: 20px;
  }
  .founder-right p {
    font-family: 'Lora', serif;
    font-size: clamp(0.85rem, 1.6vw, 1.15rem);
    line-height: 1.75;
    letter-spacing: -0.01em;
    color: #D2CEC8;
    margin-bottom: 20px;
  }

  /* ═══ GOLD CTA ═══ */
  .gold-cta {
    display: inline-block;
    font-family: 'Outfit', sans-serif;
    font-size: clamp(0.8rem, 1.4vw, 1.05rem);
    font-weight: 700;
    letter-spacing: -0.012em;
    color: #D2CEC8;
    line-height: 2.4;
    transition: opacity 0.2s;
    position: relative;
    padding-bottom: 6px;
  }
  .gold-cta::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: min(100%, 200px);
    height: 3px;
    background: #FFD53B;
  }
  .gold-cta:hover { opacity: 0.75; }
  .gold-cta.small { font-size: clamp(0.75rem, 1.2vw, 0.95rem); }

  /* ═══ HOW WE OPERATE ═══ */
  .operate {
    background: #43330B;
    padding: 0 0 80px;
  }
  .section-heading {
    font-family: 'Lora', serif;
    font-size: clamp(2rem, 5.5vw, 3.8rem);
    font-weight: 400;
    color: #D2CEC8;
    line-height: 0.57;
    letter-spacing: -0.01em;
    text-align: center;
    margin-bottom: 48px;
  }
  .section-heading.dark { color: #1a1a14; }
  .operate-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .op-card { text-align: center; }
  .op-icon {
    margin-bottom: 20px;
    display: flex;
    justify-content: center;
  }
  .op-card h3 {
    font-family: 'Outfit', sans-serif;
    font-size: clamp(1rem, 2.2vw, 1.5rem);
    color: #D2CEC8;
    margin-bottom: 12px;
    font-weight: 700;
    letter-spacing: -0.012em;
    line-height: 1.7;
  }
  .op-card p {
    font-family: 'Lora', serif;
    font-size: clamp(0.8rem, 1.4vw, 1.05rem);
    color: #D2CEC8;
    line-height: 1.75;
    letter-spacing: -0.01em;
    margin-bottom: 16px;
  }

  /* ═══ VIDEOS SECTION ═══ */
  .videos-section {
    background: #faf8f3;
    padding: 72px 0;
  }
  .section-sub {
    text-align: center;
    font-size: 0.9rem;
    color: #777;
    margin-top: -32px;
    margin-bottom: 40px;
  }
  .section-sub.light { color: rgba(245,237,212,0.5); }
  .video-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .video-card {
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .video-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.08);
  }
  .video-thumb {
    position: relative;
    overflow: hidden;
    border-radius: 12px;
  }
  .video-thumb img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .video-card:hover .video-thumb img { transform: scale(1.05); }
  .play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 48px;
    height: 48px;
    background: rgba(0,0,0,0.55);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4px);
  }
  .vid-duration {
    position: absolute;
    top: 12px;
    right: 12px;
    background: rgba(74,68,0,0.85);
    color: var(--cream);
    font-size: 0.68rem;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 20px;
  }
  .video-card h3 {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--text-dark);
    margin: 14px 0 6px;
  }
  .video-card p {
    font-size: 0.82rem;
    color: #888;
    line-height: 1.5;
  }

  /* ═══ OUTLINE BTN ═══ */
  .section-cta-wrap { text-align: center; margin-top: 36px; }
  .outline-btn {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 600;
    padding: 10px 28px;
    border: 1.5px solid var(--text-dark);
    border-radius: 50px;
    color: var(--text-dark);
    transition: all 0.25s ease;
  }
