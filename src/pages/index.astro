---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
---

<BaseLayout title="Mycelium — Free Permaculture Education">
  <Nav />

  <!-- HERO -->
  <section class="hero">
    <div class="container hero-inner">
      <h1 class="hero-heading">
        What if it's time<br>we look <em>down</em><br>to move forward?
      </h1>
    </div>
  </section>

  <!-- PHOTO GRID -->
  <section class="photo-grid">
    <div class="container">
      <div class="grid-3">
        <img src="https://mycelium-learn.com/wp-content/uploads/2024/11/pexels-photo-2132250.jpeg" alt="Permaculture garden" loading="lazy">
        <img src="https://mycelium-learn.com/wp-content/uploads/2024/11/pexels-photo-8092437.jpeg" alt="Mycelium network" loading="lazy">
        <img src="https://mycelium-learn.com/wp-content/uploads/2024/11/pexels-photo-4505166.jpeg" alt="Composting" loading="lazy">
      </div>
    </div>
  </section>

  <!-- MISSION STATEMENT -->
  <section class="mission">
    <div class="container">
      <p class="mission-text">Building food security<br>starts with education.</p>
    </div>
  </section>

  <!-- STATS -->
  <section class="stats">
    <div class="container">
      <h2 class="stats-heading">Mycelium Resources and Content to Date</h2>
      <div class="stats-grid">
        <div class="stat">
          <span class="stat-number">240</span>
          <span class="stat-label">Curated Resources</span>
        </div>
        <div class="stat">
          <span class="stat-number">600+</span>
          <span class="stat-label">People Reached</span>
        </div>
        <div class="stat">
          <span class="stat-number">1</span>
          <span class="stat-label">Platform for All</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FOUNDER -->
  <section class="founder">
    <div class="container founder-inner">
      <div class="founder-image">
        <div class="founder-photo-wrapper">
          <img src="https://mycelium-learn.com/wp-content/uploads/2024/11/founder-photo.jpg" alt="Tax Riego" loading="lazy">
          <span class="founder-annotation">That's me! →</span>
        </div>
      </div>
      <div class="founder-text">
        <h2>Why did I build Mycelium at 16?</h2>
        <p>After my Permaculture Design Certificate course in Nueva Ecija, I realized that so much indigenous knowledge about sustainable farming exists only in the minds of elders and practitioners. If we don't document it, it disappears.</p>
        <p>I thought — I'm 16, I know tech, I can build a bridge between the knowledge holders and the people who need it. That's Mycelium.</p>
        <a href="/about" class="cta-link">READ MY STORY</a>
      </div>
    </div>
  </section>

  <!-- HOW WE OPERATE -->
  <section class="operate">
    <div class="container">
      <h2 class="section-title">How We Operate</h2>
      <div class="operate-grid">
        <div class="operate-card">
          <div class="operate-icon">🔓</div>
          <h3>Zero Gatekeeping</h3>
          <p>Every resource is free and accessible. No paywalls, no barriers, no subscriptions. Permaculture knowledge belongs to everyone.</p>
        </div>
        <div class="operate-card">
          <div class="operate-icon">🔍</div>
          <h3>We Verify Every Resource</h3>
          <p>Content is reviewed by practitioners and our editorial board to ensure accuracy and respect for indigenous knowledge.</p>
        </div>
        <div class="operate-card">
          <div class="operate-icon">🤝</div>
          <h3>Expert Partners</h3>
          <p>We work with the Philippine Permaculture Association, Baganihan Collective, and indigenous knowledge holders across the Philippines.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="final-cta">
    <div class="container">
      <h2>Traditional permaculture knowledge — documented, verified, and free.</h2>
      <p>Explore the full collection at Mycelium.</p>
      <a href="/resources" class="cta-button">Start Your Journey</a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <span class="logo-text">MYCELIUM</span>
        <p>Free permaculture education for the Philippines.</p>
      </div>
      <div class="footer-links">
        <a href="/about">About</a>
        <a href="/videos">Videos</a>
        <a href="/resources">Resources</a>
        <a href="/events">Events</a>
      </div>
      <div class="footer-social">
        <a href="https://instagram.com/mycelium.learn" target="_blank">Instagram</a>
      </div>
    </div>
  </footer>
</BaseLayout>

<style>
  .hero {
    background: var(--olive);
    padding: 120px 0 80px;
    text-align: center;
  }
  .hero-heading {
    font-family: var(--font-serif);
    font-size: 3.8rem;
    font-weight: 400;
    font-style: italic;
    color: var(--cream);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }
  .hero-heading em {
    text-decoration: underline;
    text-decoration-color: var(--gold);
    text-underline-offset: 6px;
  }
  .photo-grid { background: var(--olive); padding: 0 0 80px; }
  .grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    border-radius: 12px;
    overflow: hidden;
  }
  .grid-3 img { width: 100%; height: 280px; object-fit: cover; }
  .mission {
    background: var(--olive);
    padding: 60px 0 80px;
    text-align: center;
  }
  .mission-text {
    font-family: var(--font-serif);
    font-size: 2.4rem;
    color: var(--cream);
    font-weight: 400;
    line-height: 1.3;
  }
  .stats {
    background: var(--charcoal);
    padding: 80px 0;
    text-align: center;
  }
  .stats-heading {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    color: var(--teal);
    margin-bottom: 48px;
    font-weight: 400;
  }
  .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; }
  .stat-number { font-size: 4rem; font-weight: 700; color: var(--white); display: block; }
  .stat-label { font-size: 0.95rem; color: rgba(255,255,255,0.6); margin-top: 8px; display: block; }
  .founder { background: var(--olive); padding: 100px 0; }
  .founder-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
  .founder-photo-wrapper { position: relative; }
  .founder-photo-wrapper img { width: 300px; height: 300px; border-radius: 50%; object-fit: cover; margin: 0 auto; display: block; }
  .founder-annotation { position: absolute; top: 20px; right: -20px; font-family: var(--font-serif); font-style: italic; color: var(--gold); font-size: 1rem; }
  .founder-text h2 { font-family: var(--font-serif); font-size: 2.2rem; color: var(--cream); margin-bottom: 20px; font-weight: 400; }
  .founder-text p { color: rgba(245,237,212,0.8); font-size: 1.05rem; margin-bottom: 16px; line-height: 1.7; }
  .cta-link { display: inline-block; margin-top: 12px; color: var(--gold); font-weight: 700; font-size: 0.9rem; letter-spacing: 0.08em; text-decoration: underline; text-underline-offset: 4px; }
  .operate { background: var(--cream); padding: 100px 0; }
  .section-title { font-family: var(--font-serif); font-size: 2.4rem; text-align: center; margin-bottom: 60px; color: var(--text-dark); font-weight: 400; }
  .operate-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; }
  .operate-card { text-align: center; padding: 32px 24px; }
  .operate-icon { font-size: 2.4rem; margin-bottom: 20px; }
  .operate-card h3 { font-family: var(--font-serif); font-size: 1.3rem; margin-bottom: 12px; color: var(--text-dark); }
  .operate-card p { font-size: 0.95rem; color: #555; line-height: 1.65; }
  .final-cta { background: var(--olive-dark); padding: 100px 0; text-align: center; }
  .final-cta h2 { font-family: var(--font-serif); font-size: 2.2rem; color: var(--cream); font-weight: 400; margin-bottom: 16px; font-style: italic; }
  .final-cta p { color: rgba(245,237,212,0.7); font-size: 1rem; margin-bottom: 32px; }
  .cta-button { display: inline-block; background: var(--charcoal); color: var(--white); padding: 14px 36px; border-radius: 50px; font-weight: 600; font-size: 0.95rem; transition: background 0.2s; }
  .cta-button:hover { background: #1a1f2d; }
  .footer { background: var(--charcoal); padding: 60px 0; }
  .footer-inner { display: flex; justify-content: space-between; align-items: flex-start; gap: 40px; }
  .footer-brand .logo-text { font-weight: 700; letter-spacing: 0.12em; color: var(--white); font-size: 1rem; }
  .footer-brand p { color: rgba(255,255,255,0.5); font-size: 0.85rem; margin-top: 8px; }
  .footer-links, .footer-social { display: flex; gap: 24px; }
  .footer-links a, .footer-social a { color: rgba(255,255,255,0.6); font-size: 0.85rem; transition: color 0.2s; }
  .footer-links a:hover, .footer-social a:hover { color: var(--white); }
  @media (max-width: 768px) {
    .hero-heading { font-size: 2.4rem; }
    .grid-3 { grid-template-columns: 1fr; }
    .grid-3 img { height: 200px; }
    .stats-grid { grid-template-columns: 1fr; gap: 32px; }
    .stat-number { font-size: 3rem; }
    .founder-inner { grid-template-columns: 1fr; text-align: center; }
    .founder-photo-wrapper img { width: 200px; height: 200px; }
    .founder-annotation { display: none; }
    .operate-grid { grid-template-columns: 1fr; }
    .mission-text { font-size: 1.8rem; }
    .final-cta h2 { font-size: 1.6rem; }
    .footer-inner { flex-direction: column; }
  }
</style>
