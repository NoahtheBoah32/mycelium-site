---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
---

<BaseLayout title="Mycelium — Free Permaculture Education">
  <div class="page-wrap">
    <div class="page-section">
      <img src="/images/page-top.png" alt="Mycelium Homepage" class="page-img" loading="eager">
      <!-- Clickable hotspots — positioned over buttons on the real site -->
      <a href="/resources" class="hotspot" style="top:5.2%;left:35%;width:30%;height:0.8%" aria-label="Start Your Journey"></a>
      <a href="/about" class="hotspot" style="top:52%;left:55%;width:18%;height:0.6%" aria-label="Read My Full Journey"></a>
    </div>
  </div>
</BaseLayout>

<style>
  .page-wrap {
    background: #1e1e1e;
  }
  .page-section {
    position: relative;
    width: 100%;
  }
  .page-img {
    width: 100%;
    height: auto;
    display: block;
  }
  .hotspot {
    position: absolute;
    display: block;
    cursor: pointer;
    /* border: 1px solid rgba(255,0,0,0.3); */ /* Uncomment to debug hotspot positions */
  }

  @media (max-width: 768px) {
    .page-img {
      width: 100%;
    }
  }
</style>
