---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
---

<BaseLayout title="Mycelium — Free Permaculture Education">
  <Nav />

  <div class="page-wrap">
    <!-- TOP SECTION: Hero through How We Operate -->
    <div class="page-section">
      <img src="/images/page-top.png" alt="Mycelium Homepage" class="page-img" loading="eager">
      <!-- Clickable hotspots -->
      <a href="/resources" class="hotspot" style="top:16.5%;left:38%;width:24%;height:1.8%" aria-label="Start Your Journey"></a>
      <a href="/about" class="hotspot" style="top:74.5%;left:24%;width:18%;height:1.2%" aria-label="Read My Full Journey"></a>
      <a href="/about" class="hotspot" style="top:93.5%;left:5%;width:12%;height:1%" aria-label="Our Mission"></a>
      <a href="/about" class="hotspot" style="top:93.5%;left:35%;width:14%;height:1%" aria-label="See Our Criteria"></a>
      <a href="/about#partners" class="hotspot" style="top:93.5%;left:72%;width:12%;height:1%" aria-label="Learn More"></a>
    </div>

    <!-- CONTINUED: Videos, Resources, Courses, Footer -->
    <div class="page-section">
      <img src="/images/page-continued.png" alt="Mycelium Content" class="page-img" loading="lazy">
      <!-- Clickable hotspots for continued section -->
      <a href="/videos" class="hotspot" style="top:18%;left:30%;width:20%;height:1.5%" aria-label="View All Videos"></a>
      <a href="/resources" class="hotspot" style="top:48%;left:32%;width:18%;height:1.5%" aria-label="View All Resources"></a>
      <a href="/courses" class="hotspot" style="top:79%;left:34%;width:16%;height:1.5%" aria-label="View All Courses"></a>
    </div>
  </div>
</BaseLayout>

<style>
  .page-wrap {
    background: #43330B;
  }
  .page-section {
    position: relative;
    max-width: 1400px;
    margin: 0 auto;
  }
  .page-img {
    width: 100%;
    height: auto;
    display: block;
  }
  .hotspot {
    position: absolute;
    display: block;
    cursor: pointer;
    /* border: 1px solid rgba(255,0,0,0.3); */ /* Uncomment to debug hotspot positions */
  }

  @media (max-width: 768px) {
    .page-img {
      width: 100%;
    }
  }
</style>
