---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
---

<BaseLayout title="Mycelium — Free Permaculture Education">
  <SiteNav />
  <div class="page-wrap">
    <div class="page-section">
      <img src="/images/page-top.png" alt="Mycelium Homepage" class="page-img" loading="eager">
    </div>
  </div>
</BaseLayout>

<style>
  .page-wrap {
    background: #1e1e1e;
  }
  .page-section {
    position: relative;
    width: 100%;
  }
  .page-img {
    width: 100%;
    height: auto;
    display: block;
  }
  .hotspot {
    position: absolute;
    display: block;
    cursor: pointer;
    /* border: 1px solid rgba(255,0,0,0.3); */ /* Uncomment to debug hotspot positions */
  }

  @media (max-width: 768px) {
    .page-img {
      width: 100%;
    }
  }
</style>
